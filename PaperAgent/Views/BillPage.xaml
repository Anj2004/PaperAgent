<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaperAgent.Views.BillPage"
             Title="BillPage">
    <VerticalStackLayout>
        <Label Text="{Binding HouseholdName}" FontSize="24" FontAttributes="Bold"/>
        <Label Text="{Binding TotalAmount, StringFormat='Total: Rs.{0}'}" FontSize="20"/>
    </VerticalStackLayout>
</ContentPage>