<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaperAgent.MainPage">
    <VerticalStackLayout>
        <TitleBar Title="{Binding HouseholdTitle}" BackgroundColor="#9F9F9F">
            <TitleBar.Content>
                <Label Text="{Binding HouseholdTitle}" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Center" VerticalOptions="Center" />
                
            </TitleBar.Content>
        </TitleBar>

    </VerticalStackLayout>

</ContentPage>
